@model NetCoreAi.Project2_ApiConsumerUI.Dtos.UpdateCustomerDto

@{
    ViewData["Title"] = "UpdateCustomer";
}

<h1>UpdateCustomer</h1>

<!doctype html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>CustomerList</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>
<body>

    <h1>UpdateCustomer</h1>
    <form method="post" asp-controller="Customer" asp-action="UpdateCustomer">
        <div class="container">
            <br /> <br />
            <div asp-validation-summary="All" class="text-danger"></div>
            <input type="hidden" asp-for="CustomerId" class="form-control" />

            <label>Musteri Adi</label>
            <input type="text" asp-for="CustomerName" class="form-control" />

            <label>Musteri Soyadi</label>
            <input type="text" asp-for="CustomerSurName" class="form-control" />

            <label>Musteri Bakiyesi</label>
            <input type="number" step="0.01" asp-for="CustomerBalance" class="form-control" />

            <button class="btn btn-dark">Musteri Guncelle</button>

        </div>
    </form>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
